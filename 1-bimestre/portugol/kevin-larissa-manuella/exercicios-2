 * Autor: Larissa dos Santos Mascoti
 * Descricao: Ler um ano e verificar se ele é bissexto.
 * 
 */
programa
{
	
	funcao inicio()
	{
		inteiro ano

    //Escreva ano
     escreva("Escreva um ano:\n")
	leia(ano)

     //Limpar console
     limpa()

      //Calcule o ano para ver se é bissexto 
      se ((ano % 4 == 0 e ano % 100 != 0) ou (ano % 400 == 0)) {
      escreva(ano, " é bissexto")
}

      //escreva se o ano não é bissexto
      senao {
      escreva(ano , " não é bissexto")
}
		
	}
}


EXERCÍCIO 2 - CLASSIFICAÇÃO DE TRIÂNGULO

/*
 * Instituição: etecvav
 * Data: 02/04/2026
 * Autor: Kevin William da Silva Souza
 * Descricao: Ler três números e verificar se eles formam um triângulo. Caso formem, identificar se é:
  Equilátero (todos os lados iguais)
  Isósceles (dois lados iguais)
  Escaleno (todos os lados diferentes)
*/
programa
{
	funcao inicio()
	{
		//  Declaração das variáveis
		real a, b, c

		//  Entrada de dados
		escreva("Digite o valor do lado A: ")
		leia(a)
		escreva("Digite o valor do lado B: ")
		leia(b)
		escreva("Digite o valor do lado C: ")
		leia(c)

		limpa() // Limpa a tela para organizar o resultado

	
		
		// Primeiro, verificamos a condição de existência do triângulo
		se (a < b + c e b < a + c e c < a + b) 
		{
			escreva("Os lados formam um triângulo: ")

			// Classificação quanto aos lados
			se (a == b e b == c) 
			{
				escreva("EQUILÁTERO\n")
				escreva("Motivo: Todos os lados são iguais.")
			}
			senao se (a == b ou a == c ou b == c) 
			{
				escreva("ISÓSCELES\n")
				escreva("Motivo: Dois lados são iguais.")
			}
			senao 
			
			{
				escreva("ESCALENO\n")
				escreva("Motivo: Todos os lados são diferentes.")
			}
		}
		senao 
		{
			// Caso não forme um triângulo
			escreva(" Não forma um triângulo essas medidas.\n")
			
		}
	}
}
