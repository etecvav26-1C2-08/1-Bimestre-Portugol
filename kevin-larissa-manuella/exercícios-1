EXERCÍCIO 8 - SALÁRIO DO VENDEDOR
/*
 * Instituição: etecvav
 * Data: 16/03/2026
 * Autor: Manuella de Oliveira Salvador
 * Descrição: O vendedor recebeu seu salário fixo acrescido de comissões de vendas. Ler o sálario fixo do vendedor, o valor de suas 
 * vendas e o percentual sobre as vendas e o percentual sobre as vendas. Calcular e exibir o salário final do vendedor.
 */
programa
{
	
	funcao inicio()
	{
     real salario_fixo
     real vendas
     real percentual_vendas

     //descobrir e ler o slário fixo do vendedor
     escreva("Qual é o salário fixo do vendedor?\n")
     leia(salario_fixo)

     //limpar o console
     limpa()

     //descobrir e ler o valor das vendas 
     escreva("Qual foi o valor das vendas do vendedor esse mês?\n")
     leia(vendas)

     //limpar console
     limpa()

     //descobrir e ler o percentual das vendas 
     escreva("Qual é o percentual sobre as vendas do vendedor?\n")
     leia(percentual_vendas)

     //limpar console
     limpa()

     //calcular e exibir o salário final do vendedor
     escreva("O salário final do vendendor neste mês será este valor em reais: ", vendas * percentual_vendas + salario_fixo)
    }
}
