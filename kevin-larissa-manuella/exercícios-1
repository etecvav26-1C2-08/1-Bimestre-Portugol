EXERCÍCIO 7 - ÁREA DO TRAPÉZIO
/*
 * Instituição: etecvav
 * Data: 12/03/2026
 * Autor: Manuella de Oliveira Salvador
 * Descrição: Ler a base menor, a base maior e a altura. Calcular e mostrara área de um trapézio: (
 * base menor + base maior) + altura / 2
*/
programa
{
	
	funcao inicio()
	{
     real base_maior
     real base_menor
     real altura
    
    //perguntar e ler a medida da base menor 
     escreva("Qual é a medida da base menor desse trapézio?\n")
     leia(base_menor)

     //limpar console
     limpa()

    //perguntar e ler a medida da base maior
     escreva("Qual é a medida da base maior desse trapézio?\n")
     leia(base_maior)

    //limpar console
     limpa()

    //perguntar e ler a medida do trapézio
     escreva("Qual é a medida da altura desse trapézio?\n")
     leia(altura)

    //limpar console
     limpa()

    //calcular a área do trapézio e exibir a resposta
     escreva("\nA área do trapézio é: ", base_menor + base_maior + altura / 2)
     
	}
}

EXERCÍCIO 8 - SALÁRIO DO VENDEDOR
/*
 * Instituição: etecvav
 * Data: 16/03/2026
 * Autor: Manuella de Oliveira Salvador
 * Descrição: O vendedor recebeu seu salário fixo acrescido de comissões de vendas. Ler o sálario fixo do vendedor, o valor de suas 
 * vendas e o percentual sobre as vendas e o percentual sobre as vendas. Calcular e exibir o salário final do vendedor.
 */
programa
{
	
	funcao inicio()
	{
     real salario_fixo
     real vendas
     real percentual_vendas

     //descobrir e ler o slário fixo do vendedor
     escreva("Qual é o salário fixo do vendedor?\n")
     leia(salario_fixo)

     //limpar o console
     limpa()

     //descobrir e ler o valor das vendas 
     escreva("Qual foi o valor das vendas do vendedor esse mês?\n")
     leia(vendas)

     //limpar console
     limpa()

     //descobrir e ler o percentual das vendas 
     escreva("Qual é o percentual sobre as vendas do vendedor?\n")
     leia(percentual_vendas)

     //limpar console
     limpa()

     //calcular e exibir o salário final do vendedor
     escreva("O salário final do vendendor neste mês será este valor em reais: ", vendas * percentual_vendas + salario_fixo)
    }
}
