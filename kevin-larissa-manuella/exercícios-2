{
	
	funcao inicio()
	{
	 //declarando as variavéis
	 real gasolina 
	 real etanol
	 real limite

      //descobrir e ler o preço da gasolina
	 escreva("Qual é o valor da gasolina?\n")
	 leia(gasolina)

      //limpar console
	 limpa()

      //descobrir e ler o valor do etanol
	 escreva("Qual é o valor do etanol?\n") 
	 leia(etanol)

      //limpar console
	 limpa()

     //especificar limite para preço
     limite = gasolina * 70 / 100

     
     escreva("--- Resultado ---\n")
	escreva("Limite para o etanol ser vantajoso: R$ ", limite, "\n")
	escreva("Preço atual do etanol: R$ ", etanol, "\n")
		


