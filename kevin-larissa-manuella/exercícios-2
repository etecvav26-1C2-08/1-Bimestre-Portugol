 * Descricao: Ler um ano e verificar se ele é bissexto.
 * 
 */
programa
{
	
	funcao inicio()
	{
		inteiro ano

    //Escreva ano
     escreva("Escreva um ano:\n")
	leia(ano)

     //Limpar console
     limpa()

